# ── Server ─────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
# Seed admin (created on first boot if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# ── Database ───────────────────────────────────────────
# PRODUCTION: set DATABASE_URL so ALL data (users, chats, workspaces, files,
# generated documents, logs) persists in PostgreSQL and survives redeploys.
# Leave empty only for local testing (data/db.json).
# DATABASE_URL=postgres://user:password@localhost:5432/uaeicp
# PGSSL=false

# ── AI Providers (all optional — demo mode works without keys) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── Skywork AI (optional — premium PPT production; PREFERRED deck engine when set) ──
# Get a key at skywork.ai. Uses the official Skywork-Skills gateway
# (api-tools.skywork.ai) with streamed progress. Decks take ~5-10 min.
# SKYWORK_API_KEY=sk-skywork-...
# SKYWORK_GATEWAY_URL=https://api-tools.skywork.ai/theme-gateway
# Force a specific deck engine regardless of configured keys: skywork | manus | claude
# PPT_ENGINE=

# ── Manus AI (optional — full agentic PowerPoint generation) ──
# When set, presentations are generated by Manus (research + design + visuals,
# 5-15 min per deck, uses Manus credits). Get a key at manus.im → Settings → API.
# MANUS_API_KEY=...
# MANUS_AGENT_PROFILE=manus-1.6

# ── Live web search (optional) ──
# Get a free key at tavily.com (recommended) or brave.com/search/api
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=...

# ── Files ──────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
GENERATED_DIR=./generated
# Optional: put local JSON/uploads/generated files outside the app folder so redeploys do not erase them.
# PERSISTENT_DIR=/home/u889046273/uaeicp-data
# DATA_FILE=/home/u889046273/uaeicp-data/data/db.json
MAX_UPLOAD_MB=25
