# ── Server ─────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
# Seed admin (created on first boot if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# ── Database ───────────────────────────────────────────
# PRODUCTION: set DATABASE_URL so ALL data (users, chats, workspaces, files,
# generated documents, logs) persists in PostgreSQL and survives redeploys.
# Leave empty only for local testing (data/db.json).
# DATABASE_URL=postgres://user:password@localhost:5432/uaeicp
# PGSSL=false

# If you do not use PostgreSQL, point PERSISTENT_DIR to a mounted/persistent
# folder outside the redeployed app directory. Otherwise redeploys can erase work.
# PERSISTENT_DIR=/var/data/uaeicp
# DATA_FILE=/var/data/uaeicp/db.json

# ── AI Providers (all optional — demo mode works without keys) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Optional: used for AI images in generated slide decks.
# IMAGE_MODEL=gpt-image-1
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── PowerPoint engine routing (optional) ──
# Default priority is Skywork when SKYWORK_API_KEY is set, then Manus, then Claude.
# Force a specific deck engine if needed: manus | skywork | claude
# PPT_ENGINE=

# ── Skywork AI (optional — premium PPT production) ──
# API uses Skywork's theme gateway; review data policy before sending sensitive material.
# SKYWORK_API_KEY=...
# Defaults are tuned to reduce failed/expensive generations on small credit balances.
# SKYWORK_GATEWAY_URL=https://api-tools.skywork.ai/theme-gateway
# SKYWORK_MAX_SLIDES=8
# SKYWORK_TIMEOUT_MS=1800000
# SKYWORK_IDLE_MS=720000

# ── Manus AI (optional — full agentic PowerPoint generation) ──
# When set, presentations are generated by Manus (research + design + visuals,
# often 15-45+ min per premium deck, uses Manus credits). Get a key at manus.im → Settings → API.
# MANUS_API_KEY=...
# MANUS_AGENT_PROFILE=manus-1.6
# Optional: how long the app keeps checking Manus before showing Retry download.
# MANUS_POLL_TIMEOUT_MS=3600000
# MANUS_POLL_INTERVAL_MS=15000

# ── Live web search (optional) ──
# Get a free key at tavily.com (recommended) or brave.com/search/api
# TAVILY_API_KEY=tvly-...
# BRAVE_API_KEY=...

# ── Files ──────────────────────────────────────────────
# Defaults to PERSISTENT_DIR/uploads and PERSISTENT_DIR/generated when set.
# UPLOAD_DIR=./data/uploads
# GENERATED_DIR=./data/generated
MAX_UPLOAD_MB=25
