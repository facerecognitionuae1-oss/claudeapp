# ── Server ─────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-to-a-long-random-string
# Seed admin (created on first boot if no users exist)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@1234

# ── Database ───────────────────────────────────────────
# Leave DATABASE_URL empty to use local JSON persistence (./data/db.json).
# Set it to use PostgreSQL (tables auto-created from server/db/schema.sql).
# DATABASE_URL=postgres://user:password@localhost:5432/uaeicp
# PGSSL=false

# ── AI Providers (all optional — demo mode works without keys) ──
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# ── Files ──────────────────────────────────────────────
UPLOAD_DIR=./data/uploads
GENERATED_DIR=./generated
MAX_UPLOAD_MB=25
